{
  "workspace": {
    "path": "workspaces",
    "docker_image": "agent_link_adaptation",
    "memory_limit": "16g",
    "pids_limit": 4096,
    "use_gpu": false
  },
  "num_workers": 10,
  "higher_is_better": true,
  "population_size": 20,
  "num_generations": 10,
  "tools_config": {
    "eval_timeout": 120
  },
  "timeout": 900,
  "task_submit_delay": 30.0,
  "prompt_path": "prompt.md",
  "num_ideas": 5,
  "agent_llm": {
    "model": "",
    "base_url": "",
    "temperature": 0.7,
    "top_p": 0.95
  },
  "manager_llm": {
    "model": "",
    "base_url": "",
    "temperature": 0.7,
    "top_p": 0.95
  }
}